{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "SFML Projesini Derle",
            "command": "/usr/bin/clang++",
            "args": [
                "-std=c++17",
                "-stdlib=libc++",
                "${workspaceFolder}/src/*.cpp",
                "-o",
                "${workspaceFolder}/game",
                "-I/opt/homebrew/include",
                "-L/opt/homebrew/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}